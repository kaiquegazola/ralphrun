{
  "name": "@kaiquegazola/ralphrun",
  "version": "0.2.0",
  "description": "CLI-agnostic autonomous build loop — fresh context per task, executor + advisor. Inspired by snarktank/ralph.",
  "type": "module",
  "bin": {
    "ralphrun": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.0",
    "which": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.0",
    "@types/which": "^3.0.4",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "keywords": [
    "ralph",
    "ralph-loop",
    "autonomous-agents",
    "agent-loop",
    "claude-code",
    "grok",
    "cursor",
    "cli",
    "ai-agent",
    "coding-agent"
  ],
  "license": "MIT"
}
